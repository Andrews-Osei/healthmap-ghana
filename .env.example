# Copy to .env and fill in real values.
# Never commit .env to git.

# --- Database (used by backend & db service) ---
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+psycopg2://healthmap:changeme@localhost:5432/healthmap

# --- Backend ---
DATA_DIR=./backend/app/data
ALLOWED_ORIGINS=http://localhost:3000
SECRET_KEY=please-generate-with-openssl-rand-hex-32

# First admin account (seeds data/users.json on first run; then use /admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-first-run

# ===========================================================================
# LLM for the AI assistant
# ===========================================================================
# Pick ONE provider with LLM_PROVIDER, then fill in that provider's key.
# The assistant falls back to deterministic rule-based answers if no key is
# set or the provider is unreachable — the app never breaks.
#
#   gemini  -> Google Gemini  (RECOMMENDED: has a free tier)
#   claude  -> Anthropic Claude
#   openai  -> OpenAI (ChatGPT)
#   ollama  -> local Ollama install (needs disk space for the model)
#   none    -> disable the LLM, use rule-based answers only
LLM_PROVIDER=gemini

# Shared
LLM_TIMEOUT=45
# LLM_DISABLED=1        # uncomment to force rule-based answers only

# --- Google Gemini (recommended, free tier) ---
# Get a key in 30s at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Alternatives: gemini-2.5-flash, gemini-1.5-flash (older), gemini-1.5-pro (higher quality)

# --- Anthropic Claude ---
# Key from https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-haiku-latest
# Alternative: claude-3-5-sonnet-latest (higher quality, pricier)

# --- OpenAI (ChatGPT) ---
# Key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Ollama (local, only if you choose LLM_PROVIDER=ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Frontend ---
NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=HealthMap Ghana
